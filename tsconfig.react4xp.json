{ // https://www.typescriptlang.org/tsconfig
	"include": [
		"./src/main/resources/**/*.tsx"
  ],
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"allowUmdGlobalAccess": true,
		"esModuleInterop": true,
		// Modern JSX transform - no need to import React
		"jsx": "react-jsx",
		"lib": [
			"DOM", // console
			"ES2015"
		],
		"module": "ES2015",
		// Graal-JS supports ESM?
		"moduleResolution": "node",
		"paths": {
			// Path mappings for Enonic XP libraries
			"/lib/menu": [
				"./node_modules/@item-enonic-types/lib-menu"
			],
			"/lib/xp/*": [
				"./node_modules/@enonic-types/lib-*"
			],
			// Path mappings for local project aliases
			"@common/*": [
				"./src/main/resources/react4xp/common/*"
			],
			"@utils/*": [
				"./src/main/resources/react4xp/utils/*"
			],
			// So one can import local files using absolute path same as
			// * react4xp resolves during build time
			// * and Enonic XP resolves during runtime
			"/*": [
				"./src/main/resources/*"
			]
			// This works during type checking
		},
		// Allow TypeScript standard library (browser APIs like DOM, fetch, etc.)
		// React components run in browser environment and need these APIs
		"noLib": false,

		// Even though the setting disables type checking for d.ts files,
		// TypeScript still type checks the code you specifically
		// refer to in your application's source code.
		"skipLibCheck": true,
		// As of 2023-03-15 GraalJS support ES2022
		// https://github.com/oracle/graaljs/blob/master/docs/user/JavaScriptCompatibility.md
		// But Almost every modern browser is still missing features from ES2017-ES2020
		// https://stackoverflow.com/questions/61835971/es7-es8-es9-es10-es11-browser-support
		// Since the output can be used both server-side (GraalJS) and
		// client-side (modern browsers) we have to use the "lowest" supported version.
		"target": "ES2015"
	}
}
